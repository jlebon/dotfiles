#!/bin/bash
set -euo pipefail

HOST_SPAWN=

if [ -z "${DISABLE_PODMAN_WRAPPER:-}" ] && \
                { [ -f /.dockerenv ] || [ -f /run/.containerenv ]; } && \
                command -v host-spawn </dev/null >/dev/null; then
        [ -z "${HOST_SPAWN_QUIET:-}" ] && echo -e "\033[1;31m> Redirecting to host podman\033[0m" >&2
        HOST_SPAWN="host-spawn -no-pty -env CONTAINER_HOST,CONTAINER_SSHKEY,REGISTRY_AUTH_FILE,${HOST_SPAWN_ENV:-}"
fi

# Use the alternate screen for subcommands with progress bar output to avoid
# polluting the scrollback history. Set HOST_SPAWN_NO_ALTSCREEN=1 to disable.
use_altscreen=
if [ -z "${HOST_SPAWN_NO_ALTSCREEN:-}" ] && [ -t 2 ] && [ "${1:-}" = "pull" ]; then
        use_altscreen=1
fi

if [ -n "${use_altscreen}" ]; then
        printf '\033[?1049h' >&2
        trap 'printf "\033[?1049l" >&2' EXIT
        $HOST_SPAWN /usr/bin/podman "$@"
        exit $?
fi

exec $HOST_SPAWN /usr/bin/podman "$@"

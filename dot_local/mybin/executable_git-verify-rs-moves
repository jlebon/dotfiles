#!/bin/bash
# Verify that between two git refs, Rust files only had code moved (reordered)
# and no semantic changes were made to function/item bodies.
#
# Usage: verify-move-only.sh <old-ref> <new-ref> <file>...
# Example: verify-move-only.sh HEAD~1 HEAD src/tar.rs src/scan.rs
#
# Exit codes:
#   0 - Only code movement detected (or no changes) in all files
#   1 - Semantic differences detected in at least one file
#   2 - Usage error

set -euo pipefail
shopt -s inherit_errexit

usage() {
    echo "Usage: ${0##*/} <old-ref> <new-ref> <file>..."
    echo "Example: ${0##*/} HEAD~1 HEAD src/tar.rs src/scan.rs"
    exit 2
}

die() {
    echo "error: $*" >&2
    exit 2
}

# --- Argument parsing ---
if [[ $# -lt 3 ]]; then
    usage
fi

old_ref="$1"
new_ref="$2"
shift 2
files=("$@")

# Validate refs exist
git rev-parse --verify "${old_ref}" >/dev/null 2>&1 || die "invalid git ref: ${old_ref}"
git rev-parse --verify "${new_ref}" >/dev/null 2>&1 || die "invalid git ref: ${new_ref}"

# --- Create temp directory ---
tmpdir=$(mktemp -d)
trap 'rm -rf "${tmpdir}"' EXIT

# --- Extract items function ---
# This awk script extracts top-level Rust items (functions, impls, structs, etc.)
# For impl/trait/mod blocks, it extracts methods within them as separate items.
# Each item is written to a separate file named by its type and name.
extract_items() {
    local input_file="$1"
    local output_dir="$2"

    awk -v outdir="${output_dir}" '
    BEGIN {
        # Top-level brace tracking
        top_brace_count = 0
        # Current container (impl/trait/mod) tracking
        in_container = 0
        container_name = ""
        container_brace_count = 0
        # Current item (fn/struct/etc) tracking
        in_item = 0
        item_text = ""
        item_name = ""
        item_type = ""
        item_brace_count = 0
        # Pending attributes/doc comments
        pending_attrs = ""
        # Counter for unique names
        item_num = 0
    }

    # Helper function to extract identifier after a keyword
    function extract_name_after(keyword,    pos, rest) {
        pos = index($0, keyword)
        if (pos == 0) return ""
        rest = substr($0, pos + length(keyword))
        gsub(/^[[:space:]]+/, "", rest)
        match(rest, /^[a-zA-Z_][a-zA-Z0-9_]*/)
        if (RSTART == 0) return ""
        return substr(rest, RSTART, RLENGTH)
    }

    # Helper to strip visibility and modifiers from line start
    function strip_modifiers(line) {
        gsub(/^[[:space:]]+/, "", line)
        if (line ~ /^pub[[:space:]]*\(/) {
            sub(/^pub[[:space:]]*\([^)]*\)[[:space:]]*/, "", line)
        } else if (line ~ /^pub[[:space:]]/) {
            sub(/^pub[[:space:]]+/, "", line)
        }
        if (line ~ /^async[[:space:]]/) {
            sub(/^async[[:space:]]+/, "", line)
        }
        if (line ~ /^unsafe[[:space:]]/) {
            sub(/^unsafe[[:space:]]+/, "", line)
        }
        if (line ~ /^default[[:space:]]/) {
            sub(/^default[[:space:]]+/, "", line)
        }
        return line
    }

    # Helper to check if line starts with keyword
    function starts_with_item(kw) {
        line = strip_modifiers($0)
        return (line ~ ("^" kw "[[:space:]<(]") || line ~ ("^" kw "$"))
    }

    # Count braces in current line
    function count_braces(    n, i, c, delta) {
        delta = 0
        n = length($0)
        for (i = 1; i <= n; i++) {
            c = substr($0, i, 1)
            if (c == "{") delta++
            else if (c == "}") delta--
        }
        return delta
    }

    # Write an item to file
    function write_item(type, name, text) {
        safe_name = type "_" name
        gsub(/[^a-zA-Z0-9_-]/, "_", safe_name)
        filename = outdir "/" safe_name
        print text > filename
        close(filename)
    }

    # Collect attributes and doc comments that precede items
    /^[[:space:]]*(#\[|#!\[|\/\/\/|\/\/!)/ && !in_item {
        pending_attrs = pending_attrs $0 "\n"
        next
    }

    # Inside a container (impl/trait/mod), look for methods
    in_container && !in_item {
        # Check for method/fn start
        if (starts_with_item("fn")) {
            in_item = 1
            item_type = "method"
            fn_name = extract_name_after("fn ")
            if (fn_name == "") fn_name = extract_name_after("fn<")
            item_name = container_name "__" fn_name
            item_text = pending_attrs $0 "\n"
            pending_attrs = ""
            item_brace_count = count_braces()
            # Check if complete on one line
            if (item_brace_count == 0 && $0 ~ /[;{}][[:space:]]*$/) {
                write_item(item_type, item_name, item_text)
                in_item = 0
                item_text = ""
            }
            next
        }
        # Check for type alias inside impl
        if (starts_with_item("type")) {
            in_item = 1
            item_type = "type"
            item_name = container_name "__" extract_name_after("type ")
            item_text = pending_attrs $0 "\n"
            pending_attrs = ""
            item_brace_count = count_braces()
            if (item_brace_count == 0 && $0 ~ /;[[:space:]]*$/) {
                write_item(item_type, item_name, item_text)
                in_item = 0
                item_text = ""
            }
            next
        }
        # Check for const inside impl
        if (starts_with_item("const")) {
            in_item = 1
            item_type = "const"
            item_name = container_name "__" extract_name_after("const ")
            item_text = pending_attrs $0 "\n"
            pending_attrs = ""
            item_brace_count = count_braces()
            if (item_brace_count == 0 && $0 ~ /;[[:space:]]*$/) {
                write_item(item_type, item_name, item_text)
                in_item = 0
                item_text = ""
            }
            next
        }
        # Track container braces
        delta = count_braces()
        container_brace_count += delta
        # Check if container is complete
        if (container_brace_count == 0) {
            in_container = 0
            container_name = ""
        }
        # Reset pending attrs on non-blank, non-attr lines
        if ($0 !~ /^[[:space:]]*$/) {
            pending_attrs = ""
        }
        next
    }

    # Inside an item, collect content
    in_item {
        item_text = item_text $0 "\n"
        delta = count_braces()
        item_brace_count += delta
        if (in_container) {
            container_brace_count += delta
        } else {
            top_brace_count += delta
        }

        # Check if item is complete
        if (item_brace_count == 0 && $0 ~ /[;{}][[:space:]]*$/) {
            write_item(item_type, item_name, item_text)
            in_item = 0
            item_text = ""
            item_name = ""
            # Check if container also ended
            if (in_container && container_brace_count == 0) {
                in_container = 0
                container_name = ""
            }
        }
        next
    }

    # Top level: detect item starts
    !in_item && !in_container {
        detected = 0

        if (starts_with_item("fn")) {
            in_item = 1
            item_type = "fn"
            item_name = extract_name_after("fn ")
            if (item_name == "") item_name = extract_name_after("fn<")
            detected = 1
        } else if (starts_with_item("impl")) {
            in_container = 1
            item_num++
            line = $0
            gsub(/^[[:space:]]+/, "", line)
            sub(/^pub[[:space:]]*(\([^)]*\)[[:space:]]*)?/, "", line)
            sub(/[[:space:]]*\{.*$/, "", line)
            sub(/[[:space:]]*$/, "", line)
            gsub(/[^a-zA-Z0-9_]/, "_", line)
            gsub(/_+/, "_", line)
            container_name = "impl_" line
            container_brace_count = count_braces()
            pending_attrs = ""
            # Check for empty impl on one line
            if (container_brace_count == 0) {
                in_container = 0
                container_name = ""
            }
            next
        } else if (starts_with_item("trait")) {
            in_container = 1
            item_num++
            container_name = "trait_" extract_name_after("trait ")
            container_brace_count = count_braces()
            pending_attrs = ""
            if (container_brace_count == 0) {
                in_container = 0
                container_name = ""
            }
            next
        } else if (starts_with_item("mod")) {
            # Check if it is a mod with body or just declaration
            if ($0 ~ /\{/) {
                in_container = 1
                item_num++
                container_name = "mod_" extract_name_after("mod ")
                container_brace_count = count_braces()
                pending_attrs = ""
                if (container_brace_count == 0) {
                    in_container = 0
                    container_name = ""
                }
                next
            } else {
                # mod declaration without body
                in_item = 1
                item_type = "mod"
                item_name = extract_name_after("mod ")
                detected = 1
            }
        } else if (starts_with_item("struct")) {
            in_item = 1
            item_type = "struct"
            item_name = extract_name_after("struct ")
            detected = 1
        } else if (starts_with_item("enum")) {
            in_item = 1
            item_type = "enum"
            item_name = extract_name_after("enum ")
            detected = 1
        } else if (starts_with_item("type")) {
            in_item = 1
            item_type = "type"
            item_name = extract_name_after("type ")
            detected = 1
        } else if (starts_with_item("const")) {
            in_item = 1
            item_type = "const"
            item_name = extract_name_after("const ")
            detected = 1
        } else if (starts_with_item("static")) {
            in_item = 1
            item_type = "static"
            item_name = extract_name_after("static ")
            detected = 1
        } else if ($0 ~ /^[[:space:]]*use[[:space:]]+/) {
            in_item = 1
            item_type = "use"
            item_num++
            item_name = "stmt_" item_num
            detected = 1
        }

        if (detected) {
            item_text = pending_attrs $0 "\n"
            pending_attrs = ""
            item_brace_count = count_braces()
            top_brace_count += item_brace_count
            # Check if item is complete on this line
            if (item_brace_count == 0 && $0 ~ /[;{}][[:space:]]*$/) {
                write_item(item_type, item_name, item_text)
                in_item = 0
                item_text = ""
                item_name = ""
            }
            next
        } else {
            # Reset pending attrs on non-blank lines
            if ($0 !~ /^[[:space:]]*$/) {
                pending_attrs = ""
            }
        }
    }
    ' "${input_file}"
}

# --- Hash items function ---
# Creates a sorted list of "hash type_name" entries
# Also saves normalized content to a parallel directory for diffing
hash_items() {
    local items_dir="$1"
    local output_file="$2"
    local normalized_dir="$3"

    mkdir -p "${normalized_dir}"
    : > "${output_file}"

    for item_file in "${items_dir}"/*; do
        [[ -f "${item_file}" ]] || continue

        item_name=$(basename "${item_file}")

        # Copy to normalized dir for later diffing (no normalization)
        cp "${item_file}" "${normalized_dir}/${item_name}"

        # Hash the normalized content
        hash=$(sha256sum "${normalized_dir}/${item_name}" | cut -d' ' -f1)

        echo "${hash} ${item_name}" >> "${output_file}"
    done

    # Sort by item name for consistent comparison
    sort -k2 -o "${output_file}" "${output_file}"
}

# --- Verify a single file ---
# Returns 0 if only moves detected, 1 if differences found
verify_file() {
    local file="$1"
    local file_tmpdir
    file_tmpdir="${tmpdir}/$(echo "${file}" | tr '/' '_')"

    mkdir -p "${file_tmpdir}"

    local old_file="${file_tmpdir}/old.rs"
    local new_file="${file_tmpdir}/new.rs"
    local old_items_dir="${file_tmpdir}/old_items"
    local new_items_dir="${file_tmpdir}/new_items"
    local old_normalized_dir="${file_tmpdir}/old_normalized"
    local new_normalized_dir="${file_tmpdir}/new_normalized"

    mkdir -p "${old_items_dir}" "${new_items_dir}"

    echo "Verifying ${file} (${old_ref} -> ${new_ref})"

    # --- Extract file versions ---
    if ! git show "${old_ref}:${file}" > "${old_file}" 2>/dev/null; then
        echo "  error: file not found in ${old_ref}: ${file}"
        return 1
    fi
    if ! git show "${new_ref}:${file}" > "${new_file}" 2>/dev/null; then
        echo "  error: file not found in ${new_ref}: ${file}"
        return 1
    fi

    # --- Extract items from both versions ---
    echo -n "  Extracting items from old version... "
    extract_items "${old_file}" "${old_items_dir}"
    old_count=$(find "${old_items_dir}" -type f | wc -l)
    echo "done (${old_count} items)"

    echo -n "  Extracting items from new version... "
    extract_items "${new_file}" "${new_items_dir}"
    new_count=$(find "${new_items_dir}" -type f | wc -l)
    echo "done (${new_count} items)"

    # --- Hash items ---
    local old_hashes="${file_tmpdir}/old_hashes.txt"
    local new_hashes="${file_tmpdir}/new_hashes.txt"

    hash_items "${old_items_dir}" "${old_hashes}" "${old_normalized_dir}"
    hash_items "${new_items_dir}" "${new_hashes}" "${new_normalized_dir}"

    # --- Compare ---
    echo -n "  Comparing... "

    # Extract just hashes (sorted) for comparison
    local old_hash_only="${file_tmpdir}/old_hash_only.txt"
    local new_hash_only="${file_tmpdir}/new_hash_only.txt"

    cut -d' ' -f1 "${old_hashes}" | sort > "${old_hash_only}"
    cut -d' ' -f1 "${new_hashes}" | sort > "${new_hash_only}"

    if diff -q "${old_hash_only}" "${new_hash_only}" >/dev/null 2>&1; then
        echo "✓ All ${old_count} items match - only code movement detected"
        return 0
    fi

    # --- Differences detected ---
    echo "✗ Differences detected:"
    echo

    # Find items only in old (removed or modified)
    local removed_hashes="${file_tmpdir}/removed_hashes.txt"
    comm -23 "${old_hash_only}" "${new_hash_only}" > "${removed_hashes}"

    # Find items only in new (added or modified)
    local added_hashes="${file_tmpdir}/added_hashes.txt"
    comm -13 "${old_hash_only}" "${new_hash_only}" > "${added_hashes}"

    # Map hashes back to names
    if [[ -s "${removed_hashes}" ]]; then
        echo "    Removed or modified (old version):"
        while read -r hash; do
            name=$(grep "^${hash} " "${old_hashes}" | cut -d' ' -f2-)
            short_hash="${hash:0:12}"
            echo "      - ${name} (${short_hash}...)"
        done < "${removed_hashes}"
        echo
    fi

    if [[ -s "${added_hashes}" ]]; then
        echo "    Added or modified (new version):"
        while read -r hash; do
            name=$(grep "^${hash} " "${new_hashes}" | cut -d' ' -f2-)
            short_hash="${hash:0:12}"
            echo "      + ${name} (${short_hash}...)"
        done < "${added_hashes}"
        echo
    fi

    # Try to match up modifications (same name, different hash) and show diffs
    echo "    Modifications (same name, different content):"
    local found_mods=0
    while read -r old_line; do
        local old_hash old_name new_line new_hash
        old_hash=$(echo "${old_line}" | cut -d' ' -f1)
        old_name=$(echo "${old_line}" | cut -d' ' -f2-)

        if new_line=$(grep " ${old_name}$" "${new_hashes}" 2>/dev/null); then
            new_hash=$(echo "${new_line}" | cut -d' ' -f1)
            if [[ "${old_hash}" != "${new_hash}" ]]; then
                echo
                echo "      ~ ${old_name}:"
                # Show the diff of the normalized (hashed) content
                diff --color=always -u \
                    --label "old/${old_name}" "${old_normalized_dir}/${old_name}" \
                    --label "new/${old_name}" "${new_normalized_dir}/${old_name}" \
                    | sed 's/^/        /' || true
                found_mods=1
            fi
        fi
    done < "${old_hashes}"

    if [[ ${found_mods} -eq 0 ]]; then
        echo "      (none detected)"
    fi

    return 1
}

# --- Main: process all files ---
overall_result=0

for file in "${files[@]}"; do
    echo
    # shellcheck disable=SC2310
    if ! verify_file "${file}"; then
        overall_result=1
    fi
    echo
done

# --- Summary ---
if [[ ${#files[@]} -gt 1 ]]; then
    echo "========================================="
    if [[ ${overall_result} -eq 0 ]]; then
        echo "✓ All ${#files[@]} files passed - only code movement detected"
    else
        echo "✗ Some files had differences"
    fi
fi

exit "${overall_result}"
